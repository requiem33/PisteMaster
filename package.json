{
  "name": "pistemaster",
  "private": true,
  "version": "0.1.0",
  "description": "PisteMaster - Fencing Tournament Management System",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python manage.py runserver",
    "dev:frontend": "cd web_frontend && npm run dev",
    "dev:electron": "cd desktop && npm run dev",
    "build": "npm run build:python && npm run build:frontend && npm run build:electron",
    "build:python": "powershell -ExecutionPolicy Bypass -File scripts/build-python.ps1",
    "build:electron": "cd desktop && npm run build:win",
    "build:frontend": "cd web_frontend && npm run build",
    "lint": "npm run lint:frontend && npm run lint:desktop",
    "lint:frontend": "cd web_frontend && npm run lint",
    "lint:desktop": "cd desktop && npm run lint || true",
    "test": "cd web_frontend && npm run test",
    "install:all": "npm install && cd web_frontend && npm install && cd ../desktop && npm install",
    "release": "npm version patch && git push --follow-tags"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}