{
  "name": "pistemaster-desktop",
  "version": "0.1.0",
  "description": "PisteMaster - Fencing Tournament Management System (Desktop)",
  "main": "./out/main/index.js",
  "author": "PisteMaster Team",
  "license": "MIT",
  "homepage": "https://github.com/pistemaster/pistemaster#readme",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --win --publish always",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.0",
    "@faker-js/faker": "^9.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.1",
    "vitest": "^4.1.0",
    "vue": "^3.4.0"
  }
}
